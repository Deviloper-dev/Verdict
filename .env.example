# ── Supabase project (Auth + Postgres) ─────────────────────────────────────
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Direct Postgres connection for server-side services.
# Dashboard → Project Settings → Database → Connection string (URI).
DATABASE_URL=postgresql://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# ── Semantic search (M3) ───────────────────────────────────────────────────
# platform.openai.com → API keys. text-embedding-3-small; cost is negligible
# at Verdict's volume (a few records/week).
OPENAI_API_KEY=sk-...

# ── Anchoring & export (M4) ────────────────────────────────────────────────
# Long random secret protecting /api/anchor-export and /api/embed-pending.
# Generate one:  openssl rand -hex 32
# Must match the ANCHOR_EXPORT_TOKEN secret in the GitHub repo.
ANCHOR_EXPORT_TOKEN=change-me

# Where the Verify page reads the public anchor from (the repo the
# anchor-chain workflow commits to). Leave unset until anchoring is set up.
ANCHOR_RAW_BASE_URL=https://raw.githubusercontent.com/YOUR-USER/YOUR-REPO/main
